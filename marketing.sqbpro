<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="marketing.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="884"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="ad_events" custom_title="0" dock_id="1" table="4,9:mainad_events"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000010100ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">-- Customer segmentation by purchase Recency &amp; Frequency (NTILE window function)
-- (plan's RFM adapted: no purchase amount in this data, so we score on
--  Recency + Frequency only)
WITH purchases AS (
  SELECT user_id,
         MAX(timestamp) AS last_purchase,
         COUNT(*)       AS freq
  FROM ad_events
  WHERE event_type = 'Purchase'
  GROUP BY user_id
)
SELECT user_id,
       last_purchase,
       freq,
       NTILE(4) OVER (ORDER BY last_purchase DESC) AS recency_quartile,
       NTILE(4) OVER (ORDER BY freq DESC)          AS frequency_quartile
FROM purchases
ORDER BY freq DESC, last_purchase DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
